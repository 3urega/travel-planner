# Copia a `.env.local` y ajusta.

# --- Proveedor LLM ---
# `ollama` (por defecto): Docker local o servidor Ollama remoto.
# `openai`: API de OpenAI (u otro endpoint compatible vía OPENAI_BASE_URL).
LLM_PROVIDER=ollama

# Modelo (nombre según el proveedor).
# Debe coincidir con un modelo instalado (nombre completo con tag, ej. llama3.1:8b).
# Listar: `ollama list` o `curl -s http://localhost:11434/api/tags | jq`
# Descargar: `ollama pull llama3.1:8b`
LLM_MODEL=llama3.1:8b

# --- Ollama (LLM_PROVIDER=ollama) ---
# Misma URL que `eurega_rag_ollama` (u otro Ollama en :11434): un solo contenedor basta.
OLLAMA_BASE_URL=http://localhost:11434/v1
# Ollama no exige clave; el SDK pide un string no vacío.
OLLAMA_API_KEY=ollama

# --- OpenAI / compatible (LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# Opcional: proxy, Azure OpenAI compatible, etc.
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Búsqueda de vuelos (FlightSearchPort) ---
# mock: datos sintéticos (por defecto). fli: puente Python + librería `flights` (ver requirements-fli.txt).
FLIGHT_SEARCH_PROVIDER=mock
# Intérprete Python para el bridge (solo si FLIGHT_SEARCH_PROVIDER=fli).
# FLIGHT_SEARCH_PYTHON=/usr/bin/python3
# Ruta al script si no usas la ruta por defecto bajo src/.../fli_search_bridge.py
# FLI_BRIDGE_SCRIPT=
# Timeout del bridge en ms (búsquedas reales suelen ser lentas).
# FLI_BRIDGE_TIMEOUT_MS=60000

# --- PostgreSQL ---
# Stack ia-travel: Postgres del compose escucha en host :15432 (ver docker-compose.yml).
DATABASE_URL=postgresql://travel:travel_dev@localhost:15432/ai_travel_agent
# Reutilizar Postgres de otro proyecto (ej. eurega_rag en :5432): crea la BD
# `ai_travel_agent` y apunta aquí, y no levantes `ia_travel_postgres`.
# DATABASE_URL=postgresql://codely:c0d3ly7v@localhost:5432/ai_travel_agent
# POSTGRES_HOST=localhost
# POSTGRES_PORT=15432
# POSTGRES_USER=travel
# POSTGRES_PASSWORD=travel_dev
# POSTGRES_DB=ai_travel_agent
